        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
        uniform token orientation = "rightHanded"
        rel material:binding = </CornellBox/Materials/GreenMaterial>
    }

    def Mesh "CeilingLight" (apiSchemas = ["MaterialBindingAPI"])
    {
        point3f[] points = [(-1.2, 9.99, 1.5), (1.2, 9.99, 1.5), (1.2, 9.99, -0.5), (-1.2, 9.99, -0.5)]
        int[] faceVertexCounts = [4]
