#usda 1.0
(
    doc = "Cornell Box - Wavefront Renderer MSc Thesis"
    defaultPrim = "CornellBox"
    upAxis = "Y"
    metersPerUnit = 0.01
)

def Xform "CornellBox"
{
    def Scope "Materials"
    {
        def Material "WhiteMaterial"
        {
            token outputs:surface.connect = </CornellBox/Materials/WhiteMaterial/Shader.outputs:surface>
            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.73, 0.73, 0.73)
                float inputs:roughness = 1.0
                float inputs:metallic = 0.0
                token outputs:surface
            }
        }

        def Material "RedMaterial"
        {
            token outputs:surface.connect = </CornellBox/Materials/RedMaterial/Shader.outputs:surface>
            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.65, 0.05, 0.05)
                float inputs:roughness = 1.0
                float inputs:metallic = 0.0
                token outputs:surface
            }
        }

        def Material "GreenMaterial"
        {
            token outputs:surface.connect = </CornellBox/Materials/GreenMaterial/Shader.outputs:surface>
            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.12, 0.45, 0.15)
                float inputs:roughness = 1.0
                float inputs:metallic = 0.0
                token outputs:surface
            }
        }

        def Material "LightMaterial"
        {
            token outputs:surface.connect = </CornellBox/Materials/LightMaterial/Shader.outputs:surface>
            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (1.0, 1.0, 1.0)
                color3f inputs:emissiveColor = (8.0, 8.0, 8.0)
                float inputs:roughness = 1.0
                token outputs:surface
            }
        }

        def Material "TallBoxMaterial"
        {
            token outputs:surface.connect = </CornellBox/Materials/TallBoxMaterial/Shader.outputs:surface>
            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.2, 0.3, 0.8)
                float inputs:roughness = 0.8
                float inputs:metallic = 0.0
                token outputs:surface
            }
        }

        def Material "ShortBoxMaterial"
        {
            token outputs:surface.connect = </CornellBox/Materials/ShortBoxMaterial/Shader.outputs:surface>
            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.9, 0.6, 0.1)
                float inputs:roughness = 0.8
                float inputs:metallic = 0.0
                token outputs:surface
            }
        }
    }

    def Mesh "Floor" (apiSchemas = ["MaterialBindingAPI"])
    {
        point3f[] points = [(-5, 0, -5), (5, 0, -5), (5, 0, 5), (-5, 0, 5)]
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
        uniform token orientation = "rightHanded"
        rel material:binding = </CornellBox/Materials/WhiteMaterial>
    }

    def Mesh "Ceiling" (apiSchemas = ["MaterialBindingAPI"])
    {
        point3f[] points = [(-5, 10, 5), (5, 10, 5), (5, 10, -5), (-5, 10, -5)]
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
        uniform token orientation = "rightHanded"
        rel material:binding = </CornellBox/Materials/WhiteMaterial>
    }

    def Mesh "BackWall" (apiSchemas = ["MaterialBindingAPI"])
